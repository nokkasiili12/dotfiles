@theme "~/.cache/wal/colors-rofi-dark.rasi"

configuration {
    show-icons:                  false;
}

entry {
    placeholder:                 "Search...";
}

listview {
    enabled:                     true;
    columns:                     1;
    lines:                       8;
    cycle:                       true;
    dynamic:                     true;
    scrollbar:                   false;
    layout:                      vertical;
    reverse:                     false;
    fixed-height:                false;
    fixed-columns:               true;
}

element {
    padding:                     8px 15px;
    spacing:                     15px;
    orientation:                 horizontal;
}

element-icon {
    enabled:                     false;
}

element-text {
    vertical-align:              0.5;
    horizontal-align:            0.0;
}
