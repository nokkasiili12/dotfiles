{
  "position": "bottom",
  "margin-top": 0,
  "margin-bottom": 0,
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "bluetooth",
    "cpu",
    "pulseaudio",
    "battery",
    "clock"
  ],
  "modules-center": [
    "custom/spotify",
    ],
  "clock": {
    "interval": 60,
    "format": "{:%H:%M}",
    "format-alt": "{:L%d %B %Y}",
    "tooltip-format": "{:L%d %B %Y}",
    "max-length": 25
  },
  "hyprland/workspaces": {
    "format": "{name}",
    "persistent-workspaces": {
      "*": 6,
    }
  },
  "custom/spotify": {
    "interval": 1,
    "return-type": "json",
    "exec": "~/.config/waybar/modules/spotify.sh",
    "exec-if": "pgrep spotify_player",
    "on-click": "hyprctl dispatch focuswindow \"title:spotify\"",
    "escape": true
  },
  "cpu": {
    "interval": 5,
    "format": "σΑç¦ {usage}%",
    "on-click": "foot --title floating-center gotop"
  },
